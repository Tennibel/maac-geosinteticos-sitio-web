RewriteEngine On

# Redirige /pagina.html -> /pagina (301, para URLs viejas o compartidas)
RewriteCond %{THE_REQUEST} \s/+([^\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Redirige /index -> / (evita URL duplicada de la home)
RewriteCond %{THE_REQUEST} \s/+index[\s?] [NC]
RewriteRule ^ / [R=301,L]

# Sirve internamente pagina.html cuando se pide /pagina (sin exponer la extensión)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^.]+)$ $1.html [NC,L]
